# --- Déploiement Vercel (G6/R5) -----------------------------------------------------
# Le front se déploie seul (root directory = web/). Les pages publiques /r/{id} lisent
# Supabase en anonyme (RLS : parties publiées seulement) — le jeu, lui, reste local
# tant que l'inférence tourne sur Ollama.

# API de jeu locale (dev). Sur Vercel, laisser vide ou pointer un backend distant.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Supabase (public) : URL du projet + clé ANON (jamais la service_role ici).
# Sans ces deux variables, /r/{id} retombe sur l'API locale (dev).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Rappel backend local (non-Vercel) : STORE_BACKEND=supabase + SUPABASE_URL +
# SUPABASE_SERVICE_KEY font écrire les parties dans Supabase (voir supabase/schema.sql).
